meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{BaseURL}}/Security/Login
  body: json
  auth: inherit
}

body:json {
  {
    "UserName": "admin",
    "Password": "TestPassword"
  }
}

script:post-response {
  bru.setEnvVar("bearer_token", res.body.results);
}

settings {
  encodeUrl: true
}
